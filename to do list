<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Stylish To-Do List</title>

  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #74ebd5, #9face6);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .app {
      background: #fff;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      display: flex;
      gap: 40px; /* space between input and list */
      width: 600px;
    }

    .left {
      width: 40%;
    }

    .right {
      width: 60%;
      max-height: 300px;
      overflow-y: auto;
      display: none; /* hidden initially */
    }

    input {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #ccc;
      margin-bottom: 10px;
      outline: none;
    }

    button {
      width: 100%;
      padding: 10px;
      border: none;
      background: #6c63ff;
      color: white;
      border-radius: 8px;
      cursor: pointer;
    }

    ul {
      padding: 0;
      margin: 0;
    }

    li {
      list-style: none;
      background: #f4f4f4;
      padding: 10px;
      margin-bottom: 10px;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
    }

    li.show-delete .delete {
      display: inline-block;
    }

    .delete {
      background: red;
      color: white;
      border: none;
      font-size: 12px;
      padding: 3px 7px;
      border-radius: 50%;
      cursor: pointer;
      display: none;
    }
  </style>
</head>

<body>

<div class="app">

  <!-- Input Section -->
  <div class="left">
    <h2>✨ Add Task</h2>
    <input type="text" id="taskInput" placeholder="Type your task...">
    <button onclick="addTask()">Add</button>
  </div>

  <!-- Task List -->
  <div class="right" id="taskSection">
    <h2>📋 Tasks</h2>
    <ul id="taskList"></ul>
  </div>

</div>

<script>
  const input = document.getElementById("taskInput");
  const taskSection = document.getElementById("taskSection");
  const taskList = document.getElementById("taskList");

  // Enter key support
  input.addEventListener("keypress", function(e) {
    if (e.key === "Enter") addTask();
  });

  function addTask() {
    const text = input.value.trim();
    if (text === "") return;

    // Show list when first task is added
    taskSection.style.display = "block";

    const li = document.createElement("li");

    const span = document.createElement("span");
    span.textContent = text;

    // Show delete button on click
    li.onclick = function () {
      li.classList.toggle("show-delete");
    };

    const btn = document.createElement("button");
    btn.textContent = "✖";
    btn.className = "delete";

    btn.onclick = function (e) {
      e.stopPropagation();
      li.remove();

      // Hide list if empty
      if (taskList.children.length === 0) {
        taskSection.style.display = "none";
      }
    };

    li.appendChild(span);
    li.appendChild(btn);
    taskList.appendChild(li);

    input.value = "";
  }
</script>

</body>
</html>
